# Desktop Familiar Integration — copy this to familiar.env and fill in your values
# The Desktop Familiar is an optional Raspberry Pi + local LLM project that provides
# ambient AI presence on your desk. session-init.sh reads its state on every prompt.
# See: https://github.com/[your-repo]/desktop-familiar (if you build one)

FAMILIAR_IP=192.168.x.x
FAMILIAR_PORT=3000
